# ─── App ────────────────────────────────────────────────────────────────────────
APP_NAME="AI Chatbot"
APP_VERSION="1.0.0"
ENVIRONMENT=development          # development | production
DEBUG=true

# ─── Security ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# ─── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://chatbot:chatbot@localhost:5432/chatbot_db
DATABASE_URL_SYNC=postgresql://chatbot:chatbot@localhost:5432/chatbot_db
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot
POSTGRES_DB=chatbot_db

# ─── Redis ───────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your-redis-password   # Uncomment in production

# ─── OpenAI ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Google Gemini ────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-1.5-pro

# Default LLM provider: "openai" or "gemini"
DEFAULT_LLM_PROVIDER=openai

# ─── Vector Database ──────────────────────────────────────────────────────────────
VECTOR_DB_PROVIDER=chroma          # "chroma" (dev) or "pinecone" (prod)
CHROMA_HOST=localhost
CHROMA_PORT=8001


# Pinecone (production only)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=chatbot-index

# ─── HuggingFace (optional — for local embeddings) ────────────────────────────────
HF_TOKEN=hf_your_token
EMBEDDING_MODEL_NAME=sentence-transformers/all-mpnet-base-v2

# ─── File Upload ─────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ─── RAG Tuning ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=6
SIMILARITY_THRESHOLD=0.7

# ─── Rate Limiting ────────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=500

# ─── External APIs ────────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-your-tavily-api-key         # Web search tool
OPENWEATHER_API_KEY=your-openweather-key        # Weather tool

# ─── Admin ───────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com

ADMIN_PASSWORD=Admin123!ChangeMe

# ─── Monitoring ──────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
LOG_LEVEL=INFO

# ─── CORS ────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ─── Next.js (Frontend) ──────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-this
BACKEND_URL=http://localhost:8000

# ─── Docker Production ────────────────────────────────────────────────────────────
DOCKER_REGISTRY=ghcr.io/your-org
APP_VERSION=latest
PROD_DOMAIN=your-domain.com
